{
    "name": "gnurun-wms-panel-frontend",
    "private": true,
    "version": "2.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "update": "ncu -u"
    },
    "dependencies": {
        "bootstrap": "^5.3.8",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-router": "^7.9.3",
        "swr": "^2.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^9.36.0",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^5.0.4",
        "eslint": "^9.36.0",
        "eslint-plugin-react-hooks": "^6.1.0",
        "eslint-plugin-react-refresh": "^0.4.23",
        "globals": "^16.4.0",
        "npm-check-updates": "^19.0.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.45.0",
        "vite": "^7.1.8"
    },
    "prettier": {
        "arrowParens": "always",
        "bracketSpacing": false,
        "embeddedLanguageFormatting": "auto",
        "htmlWhitespaceSensitivity": "css",
        "insertPragma": false,
        "jsxBracketSameLine": false,
        "jsxSingleQuote": false,
        "printWidth": 120,
        "proseWrap": "preserve",
        "quoteProps": "as-needed",
        "requirePragma": false,
        "semi": true,
        "singleQuote": true,
        "tabWidth": 4,
        "trailingComma": "none",
        "useTabs": false,
        "vueIndentScriptAndStyle": false
    }
}
